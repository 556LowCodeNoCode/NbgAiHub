{
  "name": "nbgaihub-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "RSS news pipeline for NbgAiHub: fetch -> dedup -> Azure OpenAI triage -> emit markdown -> editorial PR.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rowanmanning/feed-parser": "^2.1.3",
    "gray-matter": "^4.0.3",
    "openai": "^5.0.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "memfs": "^4.11.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.6"
  }
}
